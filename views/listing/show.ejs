<% layout("layouts/boilerplate") -%>
  <div class="listing-show">
    <h2 class="mb-3">
      <%= reqData.title %>
    </h2>

    <img class="listing-show__image mb-3" src="<%= reqData.image.url %>" alt="<%= reqData.title %>" />

    <p class="listing-show__desc">
      <b>Owned By </b>
      <i>
        <%= reqData.owner.username %>
      </i>
    </p>
    <p class="listing-show__desc">
      <%= reqData.description %>
    </p>
    <p class="mb-1"><span class="text-muted">Location:</span>
      <%= reqData.location %>
    </p>
    <p class="mb-1"><span class="text-muted">Price:</span> &#8377;<%= reqData.price.toLocaleString("en-IN") %>
    </p>
    <p class="mb-3"><span class="text-muted">Country:</span>
      <%= reqData.country %>
    </p>
    <% if (currUser && currUser._id.equals(reqData.owner._id)) {%>
      <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-secondary" href="/listing/<%= reqData._id %>/edit">Edit</a>
        <form action="/listing/<%= reqData._id %>?_method=DELETE" method="post">
          <button class="btn btn-danger" type="submit">Delete</button>
        </form>
      </div>
      <% } %>
        <hr class="my-4" />

        <div class="review-section row g-4 align-items-start">
          <div class="col-12 col-lg-5">
            <div class="card review-card shadow-sm">
              <div class="card-body">
                <h4 class="card-title mb-3">Leave a review</h4>

                <form class="needs-validation" action="/listing/<%= reqData._id %>/review" method="post" novalidate>
                  <div class="mb-3">
                    <label class="form-label d-block mb-2">Rating</label>
                    <div class="btn-group review-rating" role="group" aria-label="Rating">
                      <input class="form-check-input btn-check" type="radio" name="review[rating]" id="rating-5"
                        value="5" required />
                      <label class="btn btn-outline-warning" for="rating-5">5 <i class="fa-solid fa-star"></i></label>

                      <input class="form-check-input btn-check" type="radio" name="review[rating]" id="rating-4"
                        value="4" required />
                      <label class="btn btn-outline-warning" for="rating-4">4 <i class="fa-solid fa-star"></i></label>

                      <input class="form-check-input btn-check" type="radio" name="review[rating]" id="rating-3"
                        value="3" required />
                      <label class="btn btn-outline-warning" for="rating-3">3 <i class="fa-solid fa-star"></i></label>

                      <input class="form-check-input btn-check" type="radio" name="review[rating]" id="rating-2"
                        value="2" required />
                      <label class="btn btn-outline-warning" for="rating-2">2 <i class="fa-solid fa-star"></i></label>

                      <input class="form-check-input btn-check" type="radio" name="review[rating]" id="rating-1"
                        value="1" required />
                      <label class="btn btn-outline-warning" for="rating-1">1 <i class="fa-solid fa-star"></i></label>
                    </div>
                    <div class="invalid-feedback">Please choose a rating.</div>
                  </div>

                  <div class="mb-3">
                    <label class="form-label" for="review-body">Comment</label>
                    <textarea class="form-control" id="review-body" name="review[comment]" rows="4"
                      placeholder="Share your experience..." required></textarea>
                    <div class="invalid-feedback">Please write a comment.</div>
                  </div>

                  <button class="btn btn-primary w-100" type="submit">Submit review</button>
                </form>
              </div>
            </div>
          </div>

          <div class="col-12 col-lg-7">
            <div class="card review-card shadow-sm">
              <div class="card-body">
                <div class="d-flex align-items-center justify-content-between gap-2 mb-3">
                  <h4 class="card-title mb-0">Reviews</h4>
                  <span class="badge text-bg-light border">
                    <%= (reqData.reviews && reqData.reviews.length) ? reqData.reviews.length : 0 %>
                  </span>
                </div>

                <% if (reqData.reviews && reqData.reviews.length) { %>
                  <div class="list-group list-group-flush">
                    <% for (let review of reqData.reviews) { %>
                      <div class="list-group-item px-0">
                        <div class="d-flex align-items-start justify-content-between gap-3">
                          <div class="review-stars text-warning">
                            <% for (let i=0; i < (review.rating || 0); i++) { %>
                              <i class="fa-solid fa-star"></i>
                              <% } %>
                                <% for (let i=(review.rating || 0); i < 5; i++) { %>
                                  <i class="fa-regular fa-star"></i>
                                  <% } %>
                          </div>
                          <div class="text-muted small ms-auto">
                            <%= review.createdAt ? new Date(review.createdAt).toLocaleDateString("en-IN") : "" %>
                          </div>
                        </div>
                        <p class="mb-0 mt-2 text-secondary">
                          <%= review.comment %>
                        </p>
                        <form method="post" action="/listing/<%=reqData._id%>/review/<%=review._id%>?_method=delete">
                          <button class=" btn
                      btn-dark btn-sm mt-2 mb-2">Delete</button>
                        </form>
                      </div>
                      <% } %>
                  </div>
                  <% } else { %>
                    <div class="alert alert-light border mb-0" role="alert">
                      No reviews yet. Be the first one to comment.
                    </div>
                    <% } %>
              </div>
            </div>
          </div>
        </div>
  </div>