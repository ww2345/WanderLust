<% layout("layouts/boilerplate") -%>

<div class="listing-form listing-form--edit">
  <div class="listing-form__card">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-4">
      <h3 class="m-0">Edit listing</h3>
      <a class="btn btn-outline-secondary btn-sm" href="/listing/<%= data._id %>">Back</a>
    </div>

    <form action="/listing/<%= data._id %>?_method=PUT" method="post" class="listing-form__form"
      enctype="multipart/form-data">
      <div class="mb-3">
        <label class="form-label" for="listing-title">Title</label>
        <input class="form-control" id="listing-title" type="text" placeholder="Enter title" name="title"
          value="<%= data.title %>" required>
      </div>

      <div class="mb-3">
        <label class="form-label" for="listing-image-url">Image URL</label>
        <input class="form-control" id="listing-image-url" type="url" placeholder="https://..." name="image"
          value="<%= data.image && data.image.url ? data.image.url : data.image %>" required>
      </div>

      <div class="mb-3">
        <label class="form-label" for="listing-category">Category</label>
        <select class="form-select" id="listing-category" name="category" required>
          <option value="" disabled <%= !selectedCategory ? "selected" : "" %>>Select a category</option>
          <% for (let category of categories) { %>
            <option value="<%= category.slug %>" <%= selectedCategory === category.slug ? "selected" : "" %>>
              <%= category.label %>
            </option>
          <% } %>
        </select>
      </div>

      <div class="mb-3">
        <label class="form-label" for="listing-image-file">Upload New Image</label>
        <input class="form-control" id="listing-image-file" type="file" name="listing[image]" accept="image/*">
      </div>

      <div class="row g-3">
        <div class="col-12 col-md-4">
          <label class="form-label" for="listing-price">Price (per night)</label>
          <input class="form-control" id="listing-price" type="number" min="0" step="1" placeholder="Enter price"
            name="price" value="<%= data.price %>" required>
        </div>

        <div class="col-12 col-md-4">
          <label class="form-label" for="listing-location">Location</label>
          <input class="form-control" id="listing-location" type="text" placeholder="Enter location" name="location"
            value="<%= data.location %>" required>
        </div>

        <div class="col-12 col-md-4">
          <label class="form-label" for="listing-country">Country</label>
          <input class="form-control" id="listing-country" type="text" placeholder="Enter country" name="country"
            value="<%= data.country %>" required>
        </div>
      </div>

      <div class="mt-3">
        <label class="form-label" for="listing-description">Description</label>
        <textarea class="form-control" id="listing-description" name="description" rows="4"
          placeholder="Enter description" required><%= data.description %></textarea>
      </div>

      <div class="d-flex gap-2 mt-4">
        <button class="btn btn-primary" type="submit">Update</button>
        <a class="btn btn-outline-secondary" href="/listing/<%= data._id %>">Cancel</a>
      </div>
    </form>
  </div>
</div>
