<% layout("layouts/boilerplate") -%>

  <div class="row justify-content-center mt-4">
    <div class="col-12 col-md-8 col-lg-5">
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <h1 class="h4 mb-3">Create your account</h1>

          <form action="/signup" method="POST" novalidate>
            <div class="mb-3">
              <label for="username" class="form-label">Username</label>
              <input id="username" name="username" class="form-control" type="text" autocomplete="username" required>
            </div>

            <div class="mb-3">
              <label for="email" class="form-label">Email</label>
              <input id="email" name="email" class="form-control" type="email" autocomplete="email" required>
            </div>

            <div class="mb-3">
              <label for="password" class="form-label">Password</label>
              <input id="password" name="password" class="form-control" type="password" autocomplete="new-password"
                minlength="6" required>
            </div>

            <button class="btn btn-danger w-100" type="submit">Sign up</button>
            <p class="text-muted mt-3 mb-0">
              Already have an account? <a href="/login">login</a>
            </p>
          </form>
        </div>
      </div>
    </div>
  </div>